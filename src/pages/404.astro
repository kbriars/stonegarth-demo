---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
---

<Layout title={`Page not found | ${site.name}`}>
  <Header />
  <main class="section">
    <div class="container">
      <h1 class="section-title">That page doesn't exist</h1>
      <p class="lead">
        No harm done. Everything you need is on the homepage, or give us a ring on
        <a href={site.phoneHref} class="phone-link">{site.phone}</a>.
      </p>
      <a href="/" class="btn">Back to the homepage</a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    min-height: 50vh;
  }

  .lead {
    max-width: 36rem;
    margin-bottom: 1.75rem;
  }
</style>
