---
import { site } from "../data/site";
import Pic from "./Pic.astro";
---

<section id="top" class="hero">
  <Pic
    name={site.hero.image}
    alt={site.hero.imageAlt}
    widths={[640, 1024, 1600, 1920]}
    sizes="100vw"
    loading="eager"
    class="hero-img"
  />
  <div class="container content">
    <h1>{site.hero.headline}</h1>
    <p class="subline">{site.hero.subline}</p>
    <div class="actions">
      <a href="#contact" class="btn btn-light">{site.hero.cta}</a>
      <a href={site.phoneHref} class="phone-link hero-phone">Call {site.phone}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(28rem, 72vh, 40rem);
    overflow: hidden;
  }

  .hero :global(.hero-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* legibility scrim over the photo, heavier behind the text */
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(13, 25, 19, 0.72) 0%,
      rgba(13, 25, 19, 0.45) 55%,
      rgba(13, 25, 19, 0.25) 100%
    );
  }

  .content {
    position: relative;
    z-index: 1;
    width: 100%;
    color: #fff;
    padding-block: 3.5rem;
  }

  h1 {
    max-width: 46rem;
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 800;
  }

  .subline {
    max-width: 34rem;
    font-size: clamp(1.0625rem, 2.2vw, 1.25rem);
    margin-bottom: 1.75rem;
  }

  .actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem 1.75rem;
  }

  .hero-phone {
    color: #fff;
    font-size: 1.3rem;
  }
</style>
